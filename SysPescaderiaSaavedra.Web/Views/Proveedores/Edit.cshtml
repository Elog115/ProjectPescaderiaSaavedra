@model SysPescaderiaSaavedra.Web.Models.Proveedores

@{
    ViewData["Title"] = "Editar Proveedor";
}

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-pencil-square me-2"></i> Editar Proveedor
        </h5>

        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="ProveedorId" />
            <input type="hidden" asp-for="Estado" />
            <input type="hidden" asp-for="FechaRegistro" />

            <div class="row g-3">

                <!-- Empresa -->
                <div class="col-md-6">
                    <label asp-for="NombreEmpresa" class="form-label fw-semibold"></label>
                    <input asp-for="NombreEmpresa" class="form-control" />
                    <span asp-validation-for="NombreEmpresa" class="text-danger small"></span>
                </div>

                <!-- Contacto -->
                <div class="col-md-6">
                    <label asp-for="Contacto" class="form-label fw-semibold"></label>
                    <input asp-for="Contacto" class="form-control" />
                    <span asp-validation-for="Contacto" class="text-danger small"></span>
                </div>

                <!-- Teléfono -->
                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Dirección -->
                <div class="col-md-8">
                    <label asp-for="Direccion" class="form-label fw-semibold"></label>
                    <input asp-for="Direccion" class="form-control" />
                    <span asp-validation-for="Direccion" class="text-danger small"></span>
                </div>

                <!-- NIT -->
                <div class="col-md-4">
                    <label asp-for="Nit" class="form-label fw-semibold"></label>
                    <input asp-for="Nit" class="form-control" />
                    <span asp-validation-for="Nit" class="text-danger small"></span>
                </div>

            </div>

            <!-- INFO ESTADO ACTUAL -->
            <div class="mt-4">
                @if (Model.Estado)
                {
                    <span class="badge bg-success">Proveedor Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Proveedor Inactivo</span>
                }
            </div>

            <!-- BOTONES -->
            <div class="mt-4 d-flex justify-content-end gap-2">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Guardar Cambios
                </button>

            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}