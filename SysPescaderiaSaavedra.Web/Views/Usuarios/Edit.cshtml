@model SysPescaderiaSaavedra.Web.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> VOLVER AL LISTADO
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-pencil-square fs-4 text-primary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">Editar Usuario</h5>
                            <small class="text-muted">Modifica la información del perfil del sistema</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                        <input type="hidden" asp-for="UsuarioId" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NombreUsuario" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="NombreUsuario" class="form-control border-start-0" placeholder="Ej: jdoe" />
                                </div>
                                <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="RolId" class="form-label fw-semibold small text-uppercase text-muted">Asignar Rol</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                                    <select asp-for="RolId" class="form-select border-start-0" asp-items="ViewBag.RolId"></select>
                                </div>
                                <span asp-validation-for="RolId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="NombreCompleto" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre y Apellido" />
                                <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" placeholder="correo@ejemplo.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ClaveHash" class="form-label fw-semibold small text-uppercase text-muted">Contraseña (Hash)</label>
                                <input asp-for="ClaveHash" class="form-control" type="password" />
                                <span asp-validation-for="ClaveHash" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FechaRegistro" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <input asp-for="FechaRegistro" class="form-control bg-light" readonly />
                                <span asp-validation-for="FechaRegistro" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mt-3">
                                <div class="form-check form-switch p-3 border rounded-3 bg-light bg-opacity-50">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="Estado" role="switch" id="estadoSwitch">
                                    <label class="form-check-label fw-bold text-dark" for="estadoSwitch">
                                        Usuario Activo
                                    </label>
                                    <div class="form-text mt-0 ps-4">Si se desactiva, el usuario no podrá acceder al sistema.</div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4 fw-bold text-muted">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd75;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .card {
        border-radius: 12px;
    }

    .input-group-text {
        border-color: #dee2e6;
    }

    /* Estilo del Switch de estado */
    .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }

    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}