@model SysPescaderiaSaavedra.Web.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h4><i class="bi bi-pencil-square"></i> Editar Usuario</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="UsuarioId" />
            <input type="hidden" asp-for="FechaRegistro" />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="RolId" class="form-label"></label>
                    <select asp-for="RolId" class="form-select" asp-items="ViewBag.RolId"></select>
                    <span asp-validation-for="RolId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="NombreUsuario" class="form-label"></label>
                    <input asp-for="NombreUsuario" class="form-control" />
                    <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Nueva Contraseña (opcional)</label>
                    <input asp-for="ClaveHash" type="password" class="form-control" />
                    <span asp-validation-for="ClaveHash" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="NombreCompleto" class="form-label"></label>
                    <input asp-for="NombreCompleto" class="form-control" />
                    <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" asp-for="Estado" />
                        <label class="form-check-label">
                            Activo
                        </label>
                    </div>
                </div>

            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Actualizar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}