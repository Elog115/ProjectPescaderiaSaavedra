@model SysPescaderiaSaavedra.Web.Models.Usuario

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> VOLVER AL LISTADO
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-person-plus fs-4 text-success"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">Crear Nuevo Usuario</h5>
                            <small class="text-muted">Complete los campos para registrar un nuevo acceso al sistema</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NombreUsuario" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-at text-muted"></i></span>
                                    <input asp-for="NombreUsuario" class="form-control border-start-0" placeholder="Nombre de login" />
                                </div>
                                <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="RolId" class="form-label fw-semibold small text-uppercase text-muted">Asignar Rol</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                                    <select asp-for="RolId" class="form-select border-start-0" asp-items="ViewBag.RolId">
                                        <option value="" selected disabled>-- Seleccione un Rol --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="RolId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="NombreCompleto" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre completo del empleado" />
                                <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label fw-semibold small text-uppercase text-muted"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" placeholder="ejemplo@correo.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="ClaveHash" class="form-label fw-semibold small text-uppercase text-muted">Contraseña Temporal</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                                    <input asp-for="ClaveHash" class="form-control border-start-0" type="password" placeholder="Mínimo 8 caracteres" />
                                </div>
                                <span asp-validation-for="ClaveHash" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4 fw-bold text-muted border">Cancelar</a>
                            <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                                <i class="bi bi-check-circle me-2"></i> Crear Usuario
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .form-control:focus, .form-select:focus {
        border-color: #19875475;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
    }

    .card {
        border-radius: 12px;
    }

    .input-group-text {
        border-color: #dee2e6;
    }

    /* Mejora de apariencia de campos readonly o deshabilitados */
    .form-control::placeholder {
        color: #adb5bd;
        font-size: 0.9rem;
    }

    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}