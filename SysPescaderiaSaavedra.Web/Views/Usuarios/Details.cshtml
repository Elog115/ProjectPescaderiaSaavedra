@model SysPescaderiaSaavedra.Web.Models.Usuario

@{
    ViewData["Title"] = "Detalles del Usuario";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> VOLVER AL LISTADO
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="bi bi-person-badge fs-4 text-info"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold text-dark">Información del Usuario</h5>
                                <p class="text-muted small mb-0">ID: @Model.UsuarioId</p>
                            </div>
                        </div>
                        <div>
                            @if (Model.Estado == true)
                            {
                                <span class="badge rounded-pill bg-success-subtle text-success px-3 border border-success-subtle">Activo</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger-subtle text-danger px-3 border border-danger-subtle">Inactivo</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 pt-2">
                    <hr class="mt-0 mb-4 opacity-25">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">@Html.DisplayNameFor(model => model.NombreUsuario)</label>
                            <span class="fs-5 fw-bold text-dark">@Html.DisplayFor(model => model.NombreUsuario)</span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">@Html.DisplayNameFor(model => model.Rol)</label>
                            <span class="badge bg-light text-dark border px-3">
                                <i class="bi bi-shield-check me-1"></i> @Html.DisplayFor(model => model.Rol.Nombre)
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">@Html.DisplayNameFor(model => model.NombreCompleto)</label>
                            <span class="text-dark">@Html.DisplayFor(model => model.NombreCompleto)</span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">@Html.DisplayNameFor(model => model.Email)</label>
                            <span class="text-primary text-decoration-underline">@Html.DisplayFor(model => model.Email)</span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">@Html.DisplayNameFor(model => model.FechaRegistro)</label>
                            <span class="text-muted"><i class="bi bi-calendar3 me-2"></i>@Model.FechaRegistro.ToString("dd MMMM, yyyy")</span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted d-block">Seguridad</label>
                            <span class="text-muted small">Clave cifrada en sistema</span>
                        </div>
                    </div>

                    <div class="mt-5 pt-3 border-top d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model?.UsuarioId" class="btn btn-primary px-4 shadow-sm">
                            <i class="bi bi-pencil me-2"></i> Editar Perfil
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            Cerrar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .bg-success-subtle {
        background-color: #e6f7ef !important;
    }

    .bg-danger-subtle {
        background-color: #fceaea !important;
    }

    .card {
        border-radius: 12px;
    }

    /* Efecto visual de "campos" */
    .form-label {
        margin-bottom: 4px;
    }

    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>