@model IEnumerable<SysPescaderiaSaavedra.Web.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom-0">
            <div class="d-flex align-items-center">
                <i class="bi bi-box me-2 fs-4 text-dark"></i>
                <h5 class="mb-0 fw-bold text-dark">Gestión de Usuarios</h5>
            </div>
            <a asp-action="Create" class="btn btn-success d-flex align-items-center shadow-sm">
                <i class="bi bi-plus-circle me-2"></i> Nuevo Usuario
            </a>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Buscar usuario por nombre, email o rol...">
                        <button id="btnClear" class="btn btn-outline-secondary px-4" type="button">Limpiar</button>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle custom-table">
                    <thead class="bg-light text-secondary text-uppercase small">
                        <tr>
                            <th class="border-0">@Html.DisplayNameFor(model => model.NombreUsuario)</th>
                            <th class="border-0">@Html.DisplayNameFor(model => model.NombreCompleto)</th>
                            <th class="border-0">@Html.DisplayNameFor(model => model.Email)</th>
                            <th class="border-0">@Html.DisplayNameFor(model => model.Rol)</th>
                            <th class="border-0 text-center">@Html.DisplayNameFor(model => model.Estado)</th>
                            <th class="border-0">@Html.DisplayNameFor(model => model.FechaRegistro)</th>
                            <th class="border-0 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="userTable">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.NombreUsuario)</td>
                                <td class="text-muted">@Html.DisplayFor(modelItem => item.NombreCompleto)</td>
                                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @Html.DisplayFor(modelItem => item.Rol.Nombre)
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.Estado == true)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3">Inactivo</span>
                                    }
                                </td>
                                <td class="text-muted">@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm border rounded">
                                        <a asp-action="Details" asp-route-id="@item.UsuarioId" class="btn btn-white btn-sm border-0" title="Ver Detalles">
                                            <i class="bi bi-boxes text-dark"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.UsuarioId" class="btn btn-white btn-sm border-0 border-start border-end" title="Editar">
                                            <i class="bi bi-pencil text-primary"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.UsuarioId" class="btn btn-white btn-sm border-0" title="Eliminar">
                                            <i class="bi bi-trash text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* (Se mantienen tus estilos anteriores) */
    .custom-table thead th {
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 15px;
        color: #6c757d;
    }

    .custom-table tbody td {
        padding: 15px;
        border-bottom: 1px solid #f8f9fa;
    }

    .bg-success-subtle {
        background-color: #e6f7ef !important;
        border: 1px solid #c3e6cb;
    }

    .bg-danger-subtle {
        background-color: #fceaea !important;
        border: 1px solid #f5c6cb;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById('searchInput');
            const btnClear = document.getElementById('btnClear');
            const tableRows = document.querySelectorAll('#userTable tr');

            // Función de búsqueda
            searchInput.addEventListener('keyup', function () {
                const searchTerm = searchInput.value.toLowerCase();

                tableRows.forEach(row => {
                    // Busca en todo el texto de la fila
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(searchTerm) ? '' : 'none';
                });
            });

            // Función Limpiar
            btnClear.addEventListener('click', function () {
                searchInput.value = '';
                tableRows.forEach(row => row.style.display = '');
                searchInput.focus();
            });
        });
    </script>
}