@model IEnumerable<SysPescaderiaSaavedra.Web.Models.Cliente>

@{
    ViewData["Title"] = "Gestión de Clientes";
}

<style>
    .table-custom thead {
        background-color: #f1f5f7;
    }

    .table-custom th {
        font-weight: 600;
        color: #0b5e6f;
        text-transform: uppercase;
        font-size: 0.75rem;
    }

    .table-custom tbody tr:hover {
        background-color: rgba(29, 211, 176, 0.08);
    }

    .badge-estado {
        font-size: 0.75rem;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 600;
        letter-spacing: .4px;
    }

    .badge-activo {
        background-color: #e6f9f3;
        color: #0f7c8d;
    }

    .badge-inactivo {
        background-color: #fdecea;
        color: #b42318;
    }

    .text-ocean {
        color: #1dd3b0;
    }
</style>

<div class="card shadow-sm rounded-4">

    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-people-fill me-2"></i> Gestión de Clientes
        </h5>

        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle"></i> Nuevo Cliente
        </a>
    </div>

    <div class="card-body">

        <!-- BUSCADOR -->
        <div class="mb-4">
            <div class="input-group">
                <span class="input-group-text bg-light">
                    <i class="bi bi-search"></i>
                </span>
                <input id="txtSearch" class="form-control"
                       placeholder="Buscar cliente..." />
                <button type="button" class="btn btn-outline-secondary" id="btnClear">
                    Limpiar
                </button>
            </div>
        </div>

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table table-hover align-middle table-custom">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Identificación</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Fecha registro</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody id="tablaBody">
                    @foreach (var c in Model)
                    {
                        <tr class="@(c.Estado ? "" : "opacity-75")">
                            <td class="fw-semibold">
                                @c.Nombre @c.Apellido
                            </td>

                            <td>@c.Identificacion</td>
                            <td>@c.Telefono</td>
                            <td>@c.Email</td>

                            <td class="text-center">
                                @if (c.Estado)
                                {
                                    <span class="badge-estado badge-activo">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-estado badge-inactivo">
                                        Inactivo
                                    </span>
                                }
                            </td>

                            <td class="text-center text-muted">
                                @c.FechaRegistro.ToString("dd/MM/yyyy")
                            </td>

                            <td class="text-end text-nowrap">

                                <a asp-action="Edit" asp-route-id="@c.ClienteId"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Editar">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>

                                <!-- FORM PARA CAMBIAR ESTADO -->
                                <form asp-action="ToggleEstado"
                                      asp-route-id="@c.ClienteId"
                                      method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()

                                    @if (c.Estado)
                                    {
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                title="Desactivar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-success"
                                                title="Activar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                </form>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<script>
    document.getElementById("txtSearch").addEventListener("keyup", function () {
        let filtro = this.value.toLowerCase();
        let filas = document.querySelectorAll("#tablaBody tr");

        filas.forEach(function (fila) {
            let textoFila = fila.innerText.toLowerCase();
            fila.style.display = textoFila.includes(filtro) ? "" : "none";
        });
    });

    document.getElementById("btnClear").addEventListener("click", function () {
        document.getElementById("txtSearch").value = "";
        let filas = document.querySelectorAll("#tablaBody tr");
        filas.forEach(fila => fila.style.display = "");
    });
</script>