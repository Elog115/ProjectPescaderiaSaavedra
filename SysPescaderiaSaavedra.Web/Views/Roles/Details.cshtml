@model SysPescaderiaSaavedra.Web.Models.Roles

@{
    ViewData["Title"] = "Editar Rol - Pescadería Saavedra";
}

<style>
    :root {
        --deep-sea: #002b44;
        --ocean-blue: #005a8d;
        --caribbean-blue: #00a8e8;
        --sea-foam: #e1f5fe;
        --pure-white: #ffffff;
        --edit-gold: #f39c12;
        --coral-accent: #ff7f50;
    }

    body {
        /* Fondo con temática de océano profundo */
        background: radial-gradient(circle at top, #004d7a 0%, #002b44 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 20px;
    }

    /* Contenedor con efecto de cristal */
    .form-container {
        max-width: 650px;
        margin: 40px auto;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-top: 8px solid var(--edit-gold);
    }

    .form-header {
        background-color: rgba(255, 249, 240, 0.8);
        padding: 30px;
        text-align: center;
        border-bottom: 2px solid #f9e3c1;
    }

        .form-header h1 {
            color: var(--deep-sea);
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -1px;
        }

            .form-header h1 i {
                color: var(--edit-gold);
                margin-right: 10px;
            }

    .form-body {
        padding: 40px;
    }

    .form-group {
        margin-bottom: 25px;
        position: relative;
    }

        .form-group label {
            color: var(--deep-sea);
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 10px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .form-control-custom {
        width: 100%;
        padding: 14px 15px 14px 45px;
        border-radius: 15px;
        border: 2px solid #e1e8ed;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        font-size: 1rem;
        background-color: #fdfdfd;
        box-sizing: border-box;
    }

        .form-control-custom:focus {
            border-color: var(--caribbean-blue);
            box-shadow: 0 0 0 4px rgba(0, 168, 232, 0.15);
            outline: none;
            background-color: #fff;
            transform: scale(1.01);
        }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 45px; /* Ajuste según la posición del label */
        color: var(--ocean-blue);
        z-index: 5;
        font-size: 1.1rem;
    }

    /* Switch de Estado estilo Náutico */
    .status-switch {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 18px;
        background: linear-gradient(to right, var(--sea-foam), #ffffff);
        border-radius: 18px;
        cursor: pointer;
        transition: 0.3s;
        border: 1px solid #d1ecfa;
    }

        .status-switch:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border-color: var(--caribbean-blue);
        }

    .form-check-input {
        width: 22px;
        height: 22px;
        cursor: pointer;
        accent-color: var(--caribbean-blue);
    }

    /* Botón de Guardado con Brillo */
    .btn-save {
        background: linear-gradient(135deg, var(--edit-gold) 0%, #e67e22 100%);
        color: white;
        border: none;
        padding: 16px 30px;
        border-radius: 50px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(243, 156, 18, 0.4);
        margin-top: 15px;
        position: relative;
        overflow: hidden;
    }

        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(243, 156, 18, 0.5);
        }

        .btn-save:active {
            transform: translateY(-1px);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--ocean-blue);
        text-decoration: none;
        font-weight: 700;
        margin-top: 25px;
        padding: 10px 20px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .back-link:hover {
            background-color: var(--sea-foam);
            color: var(--deep-sea);
        }

    .readonly-field {
        background-color: #f8f9fa !important;
        border-style: dashed !important;
        color: #888;
    }

    /* Iconos decorativos de burbujas en el fondo */
    .bubbles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        pointer-events: none;
        opacity: 0.1;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="bubbles">
    <i class="fas fa-circle" style="position:absolute; top:10%; left:5%; font-size: 20px;"></i>
    <i class="fas fa-circle" style="position:absolute; top:30%; left:85%; font-size: 40px;"></i>
    <i class="fas fa-circle" style="position:absolute; top:70%; left:15%; font-size: 15px;"></i>
    <i class="fas fa-circle" style="position:absolute; top:85%; left:90%; font-size: 30px;"></i>
</div>

<div class="form-container">
    <div class="form-header">
        <h1><i class="fas fa-anchor"></i> Editar Rol</h1>
        <p class="text-muted" style="margin-top: 5px; font-size: 0.95rem;">Modificando credenciales de <strong>@Model.Nombre</strong></p>
    </div>

    <div class="form-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; font-weight: bold;"></div>
            <input type="hidden" asp-for="RolId" />

            <div class="form-group">
                <label asp-for="Nombre"></label>
                <i class="fas fa-tag input-icon"></i>
                <input asp-for="Nombre" class="form-control-custom" placeholder="Nombre del rol" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Descripcion"></label>
                <i class="fas fa-comment-dots input-icon"></i>
                <input asp-for="Descripcion" class="form-control-custom" placeholder="¿Qué responsabilidades tiene?" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="status-switch">
                    <input class="form-check-input" asp-for="Estado" />
                    <span style="color: var(--deep-sea); font-weight: 700; font-size: 1rem;">
                        <i class="fas fa-power-off" style="margin-right: 8px;"></i> @Html.DisplayNameFor(model => model.Estado) del Rol
                    </span>
                </label>
            </div>

            <div class="form-group">
                <label asp-for="FechaRegistro"></label>
                <i class="fas fa-calendar-check input-icon"></i>
                <input asp-for="FechaRegistro" class="form-control-custom readonly-field" readonly />
                <span asp-validation-for="FechaRegistro" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-top: 40px;">
                <button type="submit" class="btn-save">
                    <i class="fas fa-fish" style="margin-right: 10px;"></i> Confirmar Cambios
                </button>
            </div>
        </form>

        <div style="text-align: center; border-top: 2px solid #f0f4f8; margin-top: 30px; padding-top: 10px;">
            <a asp-action="Index" class="back-link">
                <i class="fas fa-chevron-left"></i> Regresar al Inventario de Roles
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}