@model SysPescaderiaSaavedra.Web.Models.Roles

@{
    ViewData["Title"] = "Editar Rol - Pescadería Saavedra";
}

<style>
    :root {
        --deep-sea: #002b44;
        --ocean-blue: #005a8d;
        --caribbean-blue: #00a8e8;
        --sea-foam: #e1f5fe;
        --pure-white: #ffffff;
        --edit-gold: #f39c12;
    }

    body {
        background-color: #f0f4f8;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .form-container {
        max-width: 650px;
        margin: 40px auto;
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        border-top: 6px solid var(--edit-gold);
    }

    .form-header {
        background-color: #fff9f0;
        padding: 25px;
        text-align: center;
        border-bottom: 1px solid #f9e3c1;
    }

        .form-header h1 {
            color: var(--deep-sea);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

    .form-body {
        padding: 35px;
    }

    .form-group {
        margin-bottom: 20px;
        position: relative;
    }

        .form-group label {
            color: var(--deep-sea);
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

    .form-control-custom {
        width: 100%;
        padding: 12px 15px 12px 40px;
        border-radius: 12px;
        border: 2px solid #e1e8ed;
        transition: all 0.3s ease;
        font-size: 1rem;
        background-color: #fafafa;
    }

        .form-control-custom:focus {
            border-color: var(--edit-gold);
            box-shadow: 0 0 0 4px rgba(243, 156, 18, 0.1);
            outline: none;
            background-color: #fff;
        }

    .input-icon {
        position: absolute;
        left: 15px;
        top: 42px;
        color: var(--ocean-blue);
        z-index: 5;
    }

    .status-switch {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 15px;
        background: var(--sea-foam);
        border-radius: 12px;
        cursor: pointer;
        transition: 0.3s;
    }

        .status-switch:hover {
            background: #d1ecfa;
        }

    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--edit-gold), #d35400);
        color: white;
        border: none;
        padding: 14px 30px;
        border-radius: 50px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(243, 156, 18, 0.3);
        margin-top: 10px;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(243, 156, 18, 0.4);
            filter: brightness(1.1);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ocean-blue);
        text-decoration: none;
        font-weight: 600;
        margin-top: 20px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: var(--caribbean-blue);
        }

    .readonly-field {
        background-color: #f1f1f1 !important;
        cursor: not-allowed;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="form-container">
    <div class="form-header">
        <h1><i class="fas fa-edit"></i> Editar Estado Actual</h1>
        <p class="text-muted" style="margin-top: 5px; font-size: 0.9rem;">Actualice la información del sistema</p>
    </div>

    <div class="form-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="RolId" />

            <div class="form-group">
                <label asp-for="Nombre"></label>
                <i class="fas fa-tag input-icon"></i>
                @* Campo bloqueado con readonly *@
                <input asp-for="Nombre" class="form-control-custom readonly-field" placeholder="Nombre del rol" readonly />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Descripcion"></label>
                <i class="fas fa-align-left input-icon"></i>
                @* Campo bloqueado con readonly *@
                <input asp-for="Descripcion" class="form-control-custom readonly-field" placeholder="Descripción detallada" readonly />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="status-switch">
                    <input class="form-check-input" asp-for="Estado" />
                    <span style="color: var(--deep-sea); font-weight: 600;">@Html.DisplayNameFor(model => model.Estado)</span>
                </label>
            </div>

            <div class="form-group">
                <label asp-for="FechaRegistro"></label>
                <i class="fas fa-calendar-alt input-icon"></i>
                <input asp-for="FechaRegistro" class="form-control-custom readonly-field" readonly />
                <span asp-validation-for="FechaRegistro" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-top: 30px;">
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Guardar Cambios
                </button>
            </div>
        </form>

        <div style="text-align: center; border-top: 1px solid #eee; margin-top: 20px;">
            <a asp-action="Index" class="back-link">
                <i class="fas fa-arrow-left"></i> Volver a la Lista
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}