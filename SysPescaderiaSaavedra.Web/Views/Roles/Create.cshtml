@model SysPescaderiaSaavedra.Web.Models.Roles

@{
    ViewData["Title"] = "Nuevo Rol - Pescadería Saavedra";
}

<style>
    :root {
        --deep-sea: #002b44;
        --ocean-blue: #005a8d;
        --caribbean-blue: #00a8e8;
        --sea-foam: #e1f5fe;
        --pure-white: #ffffff;
    }

    body {
        background-color: #f0f4f8;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .form-container {
        max-width: 600px;
        margin: 40px auto;
        background: white;
        padding: 0;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        border-top: 6px solid var(--ocean-blue);
    }

    .form-header {
        background-color: var(--sea-foam);
        padding: 25px;
        text-align: center;
        border-bottom: 1px solid #e0eef5;
    }

        .form-header h1 {
            color: var(--deep-sea);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

    .form-body {
        padding: 35px;
    }

    .form-group {
        margin-bottom: 20px;
        position: relative;
    }

        .form-group label {
            color: var(--deep-sea);
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

    /* Inputs estilizados con bordes redondeados */
    .form-control-custom {
        width: 100%;
        padding: 12px 15px 12px 40px;
        border-radius: 12px;
        border: 2px solid #e1e8ed;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .form-control-custom:focus {
            border-color: var(--caribbean-blue);
            box-shadow: 0 0 0 4px rgba(0, 168, 232, 0.1);
            outline: none;
        }

    .input-icon {
        position: absolute;
        left: 15px;
        top: 42px; /* Ajustado según el label */
        color: var(--ocean-blue);
        z-index: 5;
    }

    /* Botones temáticos */
    .btn-submit {
        background: linear-gradient(135deg, var(--caribbean-blue), var(--ocean-blue));
        color: white;
        border: none;
        padding: 14px 30px;
        border-radius: 50px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 168, 232, 0.3);
        margin-top: 10px;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 168, 232, 0.4);
            filter: brightness(1.1);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ocean-blue);
        text-decoration: none;
        font-weight: 600;
        margin-top: 20px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: var(--caribbean-blue);
            text-decoration: underline;
        }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="form-container">
    <div class="form-header">
        <h1><i class="fas fa-id-badge"></i> Nuevo Rol</h1>
        <p class="text-muted" style="margin-top: 5px; font-size: 0.9rem;">Defina los privilegios del personal</p>
    </div>

    <div class="form-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Nombre"></label>
                <i class="fas fa-tag input-icon"></i>
                <input asp-for="Nombre" class="form-control-custom" placeholder="Ej: Administrador, Vendedor..." />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Descripcion"></label>
                <i class="fas fa-align-left input-icon"></i>
                <input asp-for="Descripcion" class="form-control-custom" placeholder="Breve descripción de las funciones" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-top: 30px;">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> Guardar Rol
                </button>
            </div>
        </form>

        <div style="text-align: center; border-top: 1px solid #eee; margin-top: 20px;">
            <a asp-action="Index" class="back-link">
                <i class="fas fa-arrow-left"></i> Volver a la Lista
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}