@model SysPescaderiaSaavedra.Web.Models.Roles

@{
    ViewData["Title"] = "Eliminar Rol - Pescadería Saavedra";
}

<style>
    :root {
        --deep-sea: #002b44;
        --ocean-blue: #005a8d;
        --sea-foam: #e1f5fe;
        --coral-danger: #e74c3c;
        --coral-dark: #c0392b;
        --pure-white: #ffffff;
    }

    body {
        background: radial-gradient(circle at top, #004d7a 0%, #002b44 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
    }

    .delete-container {
        max-width: 600px;
        margin: 50px auto;
        background: rgba(255, 255, 255, 0.98);
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        overflow: hidden;
        border-top: 8px solid var(--coral-danger);
    }

    .delete-header {
        background-color: #fff5f5;
        padding: 30px;
        text-align: center;
        border-bottom: 1px solid #fed7d7;
    }

        .delete-header i {
            color: var(--coral-danger);
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .delete-header h2 {
            color: var(--deep-sea);
            font-weight: 800;
            margin: 0;
            font-size: 1.6rem;
        }

    .warning-text {
        color: #c53030;
        font-weight: 600;
        margin-top: 10px;
        background: #feb2b2;
        display: inline-block;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.9rem;
    }

    .delete-body {
        padding: 40px;
    }

    /* Estilo de lista de detalles */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
        margin-bottom: 35px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 20px;
        background: var(--sea-foam);
        border-radius: 12px;
        border-left: 4px solid var(--ocean-blue);
    }

    .info-label {
        font-weight: 800;
        color: var(--deep-sea);
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .info-value {
        color: #444;
        font-weight: 500;
    }

    /* Botones de acción */
    .action-area {
        display: flex;
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }

    .btn-confirm-delete {
        background: linear-gradient(135deg, var(--coral-danger) 0%, var(--coral-dark) 100%);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 50px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(231, 76, 60, 0.4);
    }

        .btn-confirm-delete:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 25px rgba(231, 76, 60, 0.5);
        }

    .btn-cancel {
        color: var(--ocean-blue);
        text-decoration: none;
        font-weight: 700;
        padding: 10px;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            color: var(--deep-sea);
            text-decoration: underline;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="delete-container">
    <div class="delete-header">
        <i class="fas fa-exclamation-triangle"></i>
        <h2>¿Eliminar este Rol?</h2>
        <span class="warning-text">Esta acción no se puede deshacer</span>
    </div>

    <div class="delete-body">
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label"><i class="fas fa-tag"></i> @Html.DisplayNameFor(model => model.Nombre)</span>
                <span class="info-value">@Html.DisplayFor(model => model.Nombre)</span>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="fas fa-align-left"></i> @Html.DisplayNameFor(model => model.Descripcion)</span>
                <span class="info-value">@Html.DisplayFor(model => model.Descripcion)</span>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="fas fa-info-circle"></i> @Html.DisplayNameFor(model => model.Estado)</span>
                <span class="info-value">@Html.DisplayFor(model => model.Estado)</span>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.FechaRegistro)</span>
                <span class="info-value">@Html.DisplayFor(model => model.FechaRegistro)</span>
            </div>
        </div>

        <form asp-action="Delete" class="action-area">
            <input type="hidden" asp-for="RolId" />
            <button type="submit" class="btn-confirm-delete">
                <i class="fas fa-trash-alt"></i> Confirmar Eliminación
            </button>
            <a asp-action="Index" class="btn-cancel">
                <i class="fas fa-arrow-left"></i> No, mantener este rol
            </a>
        </form>
    </div>
</div>