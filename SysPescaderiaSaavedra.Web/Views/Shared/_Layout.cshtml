<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"]?.ToString() ?? "Pescadería Saavedra") - Pescadería Saavedra</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f7fa;
        }

        /* ===== NAVBAR PREMIUM ===== */
        .navbar-ocean {
            background: linear-gradient(135deg, #0b5e6f, #0f7c8d);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand {
            font-weight: 600;
            letter-spacing: 1px;
            font-size: 1.2rem;
        }

        .nav-link {
            font-weight: 500;
            transition: all 0.2s ease-in-out;
        }

            .nav-link:hover {
                transform: translateY(-2px);
                opacity: 0.9;
            }

        /* Dashboard destacado */
        .btn-dashboard {
            background: #1dd3b0;
            color: #003844 !important;
            font-weight: 600;
            border-radius: 50px;
            padding: 6px 18px;
            transition: 0.3s ease;
        }

            .btn-dashboard:hover {
                background: #17b89c;
                transform: scale(1.05);
            }

        /* Dropdown moderno */
        .dropdown-menu {
            border-radius: 12px;
            border: none;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        }

        .dropdown-item:hover {
            background-color: #e9f7f9;
        }

        /* ===== CONTENIDO ===== */
        main {
            min-height: 75vh;
        }

        .container-custom {
            max-width: 1400px;
        }

        /* ===== FOOTER ===== */
        footer {
            background: #ffffff;
            padding: 20px 0;
            font-size: 14px;
            box-shadow: 0 -3px 10px rgba(0, 0, 0, 0.05);
        }

            footer strong {
                color: #0f7c8d;
            }
    </style>
</head>

<body>

    <!-- ===== NAVBAR ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-ocean">
            <div class="container container-custom">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-water"></i> Pescadería Saavedra
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- IZQUIERDA -->
                    <ul class="navbar-nav me-auto align-items-lg-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Inicio
                            </a>
                        </li>

                        <li class="nav-item mx-lg-3">
                            <a class="btn btn-dashboard"
                               asp-controller="Dashboard"
                               asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        <!-- Ventas -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-cart-check"></i> Ventas
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Index">Historial</a></li>
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Create">Nueva Venta</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                            </ul>
                        </li>

                        <!-- Compras -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam"></i> Compras
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="IngresoMercaderias" asp-action="Index">Ingresos</a></li>
                                <li><a class="dropdown-item" asp-controller="Proveedores" asp-action="Index">Proveedores</a></li>
                            </ul>
                        </li>

                        <!-- Inventario -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-tags"></i> Inventario
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Productos" asp-action="Index">Productos</a></li>
                                <li><a class="dropdown-item" asp-controller="Categorias" asp-action="Index">Categorías</a></li>
                                <li><a class="dropdown-item" asp-controller="Lotes" asp-action="Index">Lotes</a></li>
                            </ul>
                        </li>

                    </ul>

                    <!-- DERECHA -->
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-gear"></i> Administración
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">Usuarios</a></li>
                                <li><a class="dropdown-item" asp-controller="Roles" asp-action="Index">Roles</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#">Cerrar Sesión</a></li>
                            </ul>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ===== CONTENIDO ===== -->
    <div class="container container-custom mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="text-center">
        <div class="container">
            © 2026 <strong>Pescadería Saavedra</strong> | Sistema de Gestión Interna
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>