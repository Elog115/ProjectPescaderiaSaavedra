
@model SysPescaderiaSaavedra.Web.Models.IngresoMercaderia

@{
    ViewData["Title"] = "Nuevo Ingreso";
}

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-plus-circle me-2"></i> Nuevo Ingreso
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Estado oculto -->
           <input type="hidden" asp-for="Estado" value="true" />

            <div class="row"> 

                <!-- PROVEEDOR -->
                <div class="col-md-6 mb-3">
                    <label asp-for="ProveedorId" class="form-label fw-semibold"></label>
                    <select asp-for="ProveedorId"
                            class="form-select"
                            asp-items="ViewBag.ProveedorId">
                        <option value="">-- Seleccione proveedor --</option>
                    </select>
                    <span asp-validation-for="ProveedorId" class="text-danger"></span>
                </div>

                <!-- USUARIO -->
                <div class="col-md-6 mb-3">
                    <label asp-for="UsuarioId" class="form-label fw-semibold"></label>
                    <select asp-for="UsuarioId"
                            class="form-select"
                            asp-items="ViewBag.UsuarioId">
                        <option value="">-- Seleccione usuario --</option>
                    </select>
                    <span asp-validation-for="UsuarioId" class="text-danger"></span>
                </div>

                <!-- TOTAL -->
                <div class="col-md-6 mb-3">
                    <label asp-for="TotalCompra" class="form-label fw-semibold"></label>
                    <input asp-for="TotalCompra"
                           type="number"
                           step="0.01"
                           class="form-control"
                           placeholder="0.00" />
                    <span asp-validation-for="TotalCompra" class="text-danger"></span>
                </div>

                <!-- FECHA (automática solo visual) -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Fecha</label>
                    <input type="text"
                           class="form-control"
                           value="@DateTime.Now.ToString("dd/MM/yyyy")"
                           disabled />
                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-between">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Guardar Ingreso
                </button>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}