@model SysPescaderiaSaavedra.Web.Models.IngresoMercaderia

@{
    ViewData["Title"] = "Editar Ingreso";
}

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-pencil-fill me-2"></i> Editar Ingreso
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="IngresoId" />
            <input type="hidden" asp-for="Estado" />

            <div class="row">

                <!-- PROVEEDOR -->
                <div class="col-md-6 mb-3">
                    <label asp-for="ProveedorId" class="form-label fw-semibold"></label>
                    <select asp-for="ProveedorId"
                            class="form-select"
                            asp-items="ViewBag.ProveedorId">
                    </select>
                    <span asp-validation-for="ProveedorId" class="text-danger"></span>
                </div>

                <!-- USUARIO -->
                <div class="col-md-6 mb-3">
                    <label asp-for="UsuarioId" class="form-label fw-semibold"></label>
                    <select asp-for="UsuarioId"
                            class="form-select"
                            asp-items="ViewBag.UsuarioId">
                    </select>
                    <span asp-validation-for="UsuarioId" class="text-danger"></span>
                </div>

                <!-- FECHA -->
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaIngreso" class="form-label fw-semibold"></label>
                    <input asp-for="FechaIngreso"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="FechaIngreso" class="text-danger"></span>
                </div>

                <!-- TOTAL -->
                <div class="col-md-6 mb-3">
                    <label asp-for="TotalCompra" class="form-label fw-semibold"></label>
                    <input asp-for="TotalCompra"
                           type="number"
                           step="0.01"
                           class="form-control" />
                    <span asp-validation-for="TotalCompra" class="text-danger"></span>
                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-between">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}