@model IEnumerable<SysPescaderiaSaavedra.Web.Models.Venta>

@{
    ViewData["Title"] = "Gestión de Ventas";
}

<style>
    .table-custom thead {
        background-color: #f1f5f7;
    }

    .table-custom th {
        font-weight: 600;
        color: #0b5e6f;
        text-transform: uppercase;
        font-size: 0.75rem;
    }

    .table-custom tbody tr:hover {
        background-color: rgba(29, 211, 176, 0.08);
    }

    .badge-estado {
        font-size: 0.75rem;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 600;
        letter-spacing: .4px;
    }

    .badge-activa {
        background-color: #e6f9f3;
        color: #0f7c8d;
    }

    .badge-anulada {
        background-color: #fdecea;
        color: #b42318;
    }
</style>

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-cart-check-fill me-2"></i> Gestión de Ventas
        </h5>

        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle"></i> Nueva Venta
        </a>
    </div>

    <div class="card-body">

        <!-- BUSCADOR -->
        <div class="mb-4">
            <div class="input-group">
                <span class="input-group-text bg-light">
                    <i class="bi bi-search"></i>
                </span>
                <input id="txtSearch" class="form-control"
                       placeholder="Buscar por cliente o fecha..." />
                <button class="btn btn-outline-secondary" id="btnClear">
                    Limpiar
                </button>
            </div>
        </div>

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table table-hover align-middle table-custom">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">Impuesto</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody id="tablaBody">
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @v.FechaVenta.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @(v.Cliente != null ? v.Cliente.Nombre : "Consumidor Final")
                            </td>

                            <td class="text-end">
                                $ @v.Subtotal.ToString("N2")
                            </td>

                            <td class="text-end">
                                $ @v.Impuesto.ToString("N2")
                            </td>

                            <td class="text-end fw-bold text-success">
                                $ @v.Total.ToString("N2")
                            </td>

                            <td class="text-center">
                                @if (v.Estado)
                                {
                                    <span class="badge-estado badge-activa">
                                        Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-estado badge-anulada">
                                        Anulada
                                    </span>
                                }
                            </td>

                            <td class="text-end text-nowrap">

                                <a asp-action="Edit"
                                   asp-route-id="@v.VentaId"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Editar">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>

                                @if (v.Estado)
                                {
                                    <a asp-action="ToggleEstado"
                                       asp-route-id="@v.VentaId"
                                       class="btn btn-sm btn-outline-danger"
                                       title="Anular">
                                        <i class="bi bi-toggle-off"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="ToggleEstado"
                                       asp-route-id="@v.VentaId"
                                       class="btn btn-sm btn-outline-success"
                                       title="Activar">
                                        <i class="bi bi-toggle-on"></i>
                                    </a>
                                }

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<!-- SCRIPT BUSCADOR -->
<script>
    document.getElementById("txtSearch").addEventListener("keyup", function () {
        let filtro = this.value.toLowerCase();
        let filas = document.querySelectorAll("#tablaBody tr");

        filas.forEach(function (fila) {
            let textoFila = fila.innerText.toLowerCase();

            if (textoFila.includes(filtro)) {
                fila.style.display = "";
            } else {
                fila.style.display = "none";
            }
        });
    });

    document.getElementById("btnClear").addEventListener("click", function () {
        document.getElementById("txtSearch").value = "";
        let filas = document.querySelectorAll("#tablaBody tr");
        filas.forEach(fila => fila.style.display = "");
    });
</script>