@model SysPescaderiaSaavedra.Web.Models.Venta?

@{
    ViewData["Title"] = "Nueva Venta";
}

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-cart-plus-fill me-2"></i> Nueva Venta
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">

                <!-- Cliente -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-person-fill me-1 text-primary"></i>
                        Cliente
                    </label>
                    <select asp-for="ClienteId"
                            class="form-select"
                            asp-items="@(ViewBag.ClienteId ?? new SelectList(Enumerable.Empty<SelectListItem>()))">
                        <option value="">Seleccione un cliente</option>
                    </select>
                    <span asp-validation-for="ClienteId" class="text-danger"></span>
                </div>

                <!-- Usuario -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-person-badge-fill me-1 text-success"></i>
                        Vendedor
                    </label>
                    <select asp-for="UsuarioId"
                            class="form-select"
                            asp-items="@(ViewBag.UsuarioId ?? new SelectList(Enumerable.Empty<SelectListItem>()))">
                        <option value="">Seleccione un vendedor</option>
                    </select>
                    <span asp-validation-for="UsuarioId" class="text-danger"></span>
                </div>

                <!-- Subtotal -->
                <div class="col-md-6">
                    <label asp-for="Subtotal" class="form-label fw-semibold"></label>
                    <input asp-for="Subtotal"
                           type="number"
                           step="0.01"
                           class="form-control"
                           id="Subtotal" />
                    <span asp-validation-for="Subtotal" class="text-danger"></span>
                </div>

                <!-- Impuesto -->
                <div class="col-md-6">
                    <label asp-for="Impuesto" class="form-label fw-semibold"></label>
                    <input asp-for="Impuesto"
                           type="number"
                           step="0.01"
                           class="form-control"
                           id="Impuesto" />
                    <span asp-validation-for="Impuesto" class="text-danger"></span>
                </div>

                <!-- Total -->
                <div class="col-md-6">
                    <label asp-for="Total" class="form-label fw-semibold"></label>
                    <input asp-for="Total"
                           type="number"
                           step="0.01"
                           class="form-control"
                           id="Total"
                           readonly />
                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>

            </div>

            <!-- BOTONES -->
            <div class="mt-4 d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <button type="submit"
                        class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Registrar Venta
                </button>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const subtotal = document.getElementById("Subtotal");
        const impuesto = document.getElementById("Impuesto");
        const total = document.getElementById("Total");

        function calcularTotal() {
            let s = parseFloat(subtotal.value) || 0;
            let i = parseFloat(impuesto.value) || 0;
            total.value = (s + i).toFixed(2);
        }

        subtotal.addEventListener("input", calcularTotal);
        impuesto.addEventListener("input", calcularTotal);
    </script>
}