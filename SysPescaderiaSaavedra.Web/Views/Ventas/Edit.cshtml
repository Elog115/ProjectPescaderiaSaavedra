@model SysPescaderiaSaavedra.Web.Models.Venta

@{
    ViewData["Title"] = "Editar Venta";
}

<div class="card shadow-sm rounded-4">

    <!-- HEADER -->
    <div class="card-header py-3">
        <h5 class="m-0 fw-bold text-ocean">
            <i class="bi bi-pencil-square me-2"></i> Editar Venta
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="VentaId" />
            <input type="hidden" asp-for="Estado" /> <!-- Se mantiene oculto -->

            <div class="row g-3">

                <!-- Cliente -->
                <div class="col-md-6">
                    <label asp-for="ClienteId" class="form-label fw-semibold"></label>
                    <select asp-for="ClienteId"
                            class="form-select"
                            asp-items="ViewBag.ClienteId">
                    </select>
                    <span asp-validation-for="ClienteId" class="text-danger"></span>
                </div>

                <!-- Usuario -->
                <div class="col-md-6">
                    <label asp-for="UsuarioId" class="form-label fw-semibold"></label>
                    <select asp-for="UsuarioId"
                            class="form-select"
                            asp-items="ViewBag.UsuarioId">
                    </select>
                    <span asp-validation-for="UsuarioId" class="text-danger"></span>
                </div>

                <!-- Fecha -->
                <div class="col-md-6">
                    <label asp-for="FechaVenta" class="form-label fw-semibold"></label>
                    <input asp-for="FechaVenta"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="FechaVenta" class="text-danger"></span>
                </div>

                <!-- Subtotal -->
                <div class="col-md-6">
                    <label asp-for="Subtotal" class="form-label fw-semibold"></label>
                    <input asp-for="Subtotal"
                           type="number"
                           step="0.01"
                           class="form-control" />
                    <span asp-validation-for="Subtotal" class="text-danger"></span>
                </div>

                <!-- Impuesto -->
                <div class="col-md-6">
                    <label asp-for="Impuesto" class="form-label fw-semibold"></label>
                    <input asp-for="Impuesto"
                           type="number"
                           step="0.01"
                           class="form-control" />
                    <span asp-validation-for="Impuesto" class="text-danger"></span>
                </div>

                <!-- Total -->
                <div class="col-md-6">
                    <label asp-for="Total" class="form-label fw-semibold"></label>
                    <input asp-for="Total"
                           type="number"
                           step="0.01"
                           class="form-control" />
                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>

            </div>

            <!-- BOTONES -->
            <div class="mt-4 d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <button type="submit"
                        class="btn btn-primary">
                    <i class="bi bi-save"></i> Guardar Cambios
                </button>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}